#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${OPENCODE_CONFIG_DIR:-$HOME/.config/opencode}"
CONFIG_FILE=""

if [ -f "$CONFIG_DIR/opencode.jsonc" ]; then
  CONFIG_FILE="$CONFIG_DIR/opencode.jsonc"
elif [ -f "$CONFIG_DIR/opencode.json" ]; then
  CONFIG_FILE="$CONFIG_DIR/opencode.json"
fi

printf 'OpenCode Token Audit\n'
printf '====================\n\n'

if [ -n "$CONFIG_FILE" ]; then
  printf 'Config: %s\n' "$CONFIG_FILE"
else
  printf 'Config: none found under %s\n' "$CONFIG_DIR"
fi

printf '\nInstalled global skills:\n'
if [ -d "$CONFIG_DIR/skills" ]; then
  find "$CONFIG_DIR/skills" -mindepth 2 -maxdepth 2 -name SKILL.md -print 2>/dev/null | sed 's#^.*/skills/##; s#/SKILL.md$##' | sort | sed 's/^/- /' || true
else
  printf '%s\n' '- none'
fi

printf '\nInstalled global agents:\n'
if [ -d "$CONFIG_DIR/agents" ] || [ -d "$CONFIG_DIR/agent" ]; then
  find "$CONFIG_DIR/agents" "$CONFIG_DIR/agent" -maxdepth 1 -type f -name '*.md' -print 2>/dev/null | sed 's#^.*/##; s#\.md$##' | sort | sed 's/^/- /' || true
else
  printf '%s\n' '- none'
fi

if [ -n "$CONFIG_FILE" ]; then
  printf '\nConfig signals:\n'
  if grep -q '"mcp"' "$CONFIG_FILE"; then
    if command -v node >/dev/null 2>&1; then
      mcp_count=$(node - "$CONFIG_FILE" <<'NODE'
const fs = require('node:fs')
const file = process.argv[2]
const raw = fs.readFileSync(file, 'utf8')
const json = raw.replace(/\/\*[\s\S]*?\*\//g, '').replace(/(^|[^:])\/\/.*$/gm, '$1').replace(/,\s*([}\]])/g, '$1')
try {
  const cfg = JSON.parse(json)
  console.log(cfg && cfg.mcp && typeof cfg.mcp === 'object' ? Object.keys(cfg.mcp).length : 0)
} catch {
  console.log('unknown')
}
NODE
)
      printf '%s\n' "- MCP block present. MCP server entries: $mcp_count"
    else
      mcp_count=$(grep -E '^[[:space:]]*"[A-Za-z0-9_.-]+"[[:space:]]*:[[:space:]]*\{' "$CONFIG_FILE" | wc -l | tr -d ' ')
      printf '%s\n' "- MCP block present. Approx object entries: $mcp_count"
    fi
  else
    printf '%s\n' '- No MCP block in global config. Project configs may still define MCP servers.'
  fi
  grep -q '"tool_output"' "$CONFIG_FILE" && printf '%s\n' '- tool_output limits configured' || printf '%s\n' '- tool_output limits missing. Consider install.sh --tune-config'
  grep -q '"compaction"' "$CONFIG_FILE" && printf '%s\n' '- compaction configured' || printf '%s\n' '- compaction config missing. Consider install.sh --tune-config'
fi

printf '\nToken minimizer checklist:\n'
printf '%s\n' '- Use skills for repeated workflows and procedural knowledge.'
printf '%s\n' '- Use CLI/scripts for orchestration and data reduction before model injection.'
printf '%s\n' '- Use MCP mainly for live read-only API/data access.'
printf '%s\n' '- Disable MCP servers that were not needed in the last two weeks.'
printf '%s\n' '- Keep tool outputs short; summarize, paginate, or filter before returning.'
